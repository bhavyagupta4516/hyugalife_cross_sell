// RENDER ENGINE
// ─────────────────────────────────────────────
function escHtml(s){return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')}
function nl2br(s){return escHtml(s).replace(/\n/g,'<br>')}
function highlightVars(s){return escHtml(s).replace(/\{\{([^}]+)\}\}/g,'<span class="var-tag">{{$1}}</span>')}

function badgeHtml(type){
  const map={TEMPLATE:'badge-template',SESSION:'badge-session',FALLBACK:'badge-fallback'};
  const lab={TEMPLATE:'Template · Meta approval required',SESSION:'Session message · free-form',FALLBACK:'Fallback template · Meta approval required'};
  return `<span class="tmpl-badge ${map[type]}">${lab[type]}</span>`;
}

function templateCard(msg, title, cat){
  const btnsHtml = (msg.btns||[]).map(b=>`<span class="tmpl-btn-tag">${escHtml(b)}</span>`).join('');
  const headerLine = msg.header ? `<div class="tmpl-row"><div class="tmpl-label">Header</div><div style="font-size:12px;color:#555">${escHtml(msg.header)}</div></div>` : '';
  const footerLine = msg.footer ? `<div class="tmpl-row" style="margin-top:8px"><div class="tmpl-label">Footer</div><div style="font-size:12px;color:#555">${escHtml(msg.footer)}</div></div>` : '';
  const tnameLine = msg.tname ? `<span class="tmpl-name">${escHtml(msg.tname)}</span>` : '';
  return `
<div class="tmpl-card">
  <div class="tmpl-card-header">
    ${badgeHtml(msg.type)}
    <span style="font-size:12px;font-weight:500;margin-left:6px;color:#333">${escHtml(title)}</span>
    ${tnameLine}
  </div>
  <div class="tmpl-body">
    ${headerLine}
    <div class="tmpl-row"><div class="tmpl-label">Body copy</div></div>
    <div class="tmpl-body-text">${highlightVars(msg.body)}</div>
    ${footerLine}
    <div class="tmpl-row" style="margin-top:8px"><div class="tmpl-label">Quick reply buttons</div></div>
    <div class="tmpl-btns">${btnsHtml}</div>
  </div>
</div>`;
}

function branchTemplateCards(cat){
  let html = '';
  cat.branches.forEach((b,i)=>{
    html += `<div style="border-left:3px solid ${b.color};padding-left:10px;margin-bottom:14px">
      <div style="font-size:11px;font-weight:700;color:${b.color};margin-bottom:6px;text-transform:uppercase;letter-spacing:.04em">Branch ${i+1}: User selects "${escHtml(b.trigger)}"</div>
      <div style="font-size:11px;color:#666;margin-bottom:8px"><strong>Surfaces L2:</strong> ${escHtml(b.l2)}</div>
      ${templateCard(b.msg2, 'MSG 2 · Narrow down', cat)}
      <div style="margin-top:8px">${templateCard(b.msg3, 'MSG 3 · Recommendation + cross-sell', cat)}</div>
      ${b.msg3.crossSell ? `<div class="cross-section"><strong>Cross-sell logic:</strong> ${escHtml(b.msg3.crossSell)}</div>` : ''}
    </div>`;
  });
  return html;
}

function simBubble(body, btns, stepLabel, catKey, branchIdx, msgType){
  const btnsHtml = btns.map((b,i)=>`<button class="flow-btn" onclick="flowClick('${catKey}',${branchIdx},${msgType},${i},this)">${escHtml(b)}</button>`).join('');
  return `
    ${stepLabel ? `<div class="step-label">${escHtml(stepLabel)}</div>` : ''}
    <div class="msg-row">
      <div class="sim-avatar" style="width:28px;height:28px;font-size:11px">H</div>
      <div class="bubble-wrap">
        <div class="bubble">${nl2br(body)}<div class="bubble-meta">12:05 PM ✓✓</div></div>
        <div class="btns-wrap">${btnsHtml}</div>
      </div>
    </div>`;
}


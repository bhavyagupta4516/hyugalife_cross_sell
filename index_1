  ${branchTemplateCards(cat)}
  <div style="margin-top:4px">
    <div style="font-size:11px;font-weight:600;color:#888;text-transform:uppercase;letter-spacing:.05em;margin-bottom:6px">T+24h fallback (no reply to MSG 1)</div>
    ${templateCard(cat.fallback, 'Fallback nudge · Outbound', cat)}
  </div>
  <div class="flow-rules" style="margin-top:12px">
    <div class="rule-item"><div class="rule-dot"></div><span><strong>Trigger delay:</strong> 15–30 min post page exit</span></div>
    <div class="rule-item"><div class="rule-dot"></div><span><strong>Suppress:</strong> purchased in last 7 days</span></div>
    <div class="rule-item"><div class="rule-dot"></div><span><strong>Max frequency:</strong> 1 re-engagement attempt per session</span></div>
    <div class="rule-item"><div class="rule-dot"></div><span><strong>Opt-out:</strong> honoured at every node — no exceptions</span></div>
  </div>
</div>`;

  return `
<div class="panel" id="panel-${cat.key}" style="--cat-color:${cat.color}">
  <div class="cat-header">
    <div class="cat-icon" style="background:${cat.bg};font-size:22px">${cat.emoji}</div>
    <div>
      <div class="cat-title">${escHtml(cat.name)}</div>
      <div class="cat-sub">${escHtml(cat.meta)}</div>
    </div>
    <span class="tone-pill" style="background:${cat.bg};color:${cat.textColor}">${escHtml(cat.tone)}</span>
  </div>
  <div class="insight"><strong>Drop-off insight:</strong> ${escHtml(cat.dropoff)}</div>
  <div class="two-col">
    ${simHtml}
    ${tmplHtml}
  </div>
</div>`;
}

// ─────────────────────────────────────────────
// FLOW INTERACTION
// ─────────────────────────────────────────────
const flowState = {};

function flowClick(catKey, branchIdx, msgType, btnIdx, el){
  const cat = CATS.find(c=>c.key===catKey);
  if(!cat) return;
  const chatEl = document.getElementById('chat-'+catKey);

  if(msgType===1){ // MSG1 clicked
    // disable all msg1 buttons
    document.querySelectorAll(`#btns1-${catKey} .flow-btn`).forEach(b=>{b.classList.add('disabled');b.classList.remove('selected')});
    el.classList.remove('disabled'); el.classList.add('selected');
    flowState[catKey] = {branch: btnIdx};
    const branch = cat.branches[btnIdx];

    // remove any existing msg2/msg3
    ['msg2-'+catKey,'msg3-'+catKey,'step2-'+catKey,'step3-'+catKey].forEach(id=>{const e=document.getElementById(id);if(e)e.remove()});

    // inject step label
    const stepDiv = document.createElement('div');
    stepDiv.id = 'step2-'+catKey; stepDiv.className='step-label';
    stepDiv.textContent = `Branch: "${branch.trigger}" → surfacing ${branch.l2.split('·')[0].trim()}`;
    chatEl.appendChild(stepDiv);

    // inject msg2
    const msg2Div = document.createElement('div');
    msg2Div.id = 'msg2-'+catKey; msg2Div.className='msg-row';
    const b2Html = branch.msg2.btns.map((b,i)=>`<button class="flow-btn" onclick="flowClick('${catKey}',${btnIdx},2,${i},this)">${escHtml(b)}</button>`).join('');
    msg2Div.innerHTML = `<div class="sim-avatar" style="width:28px;height:28px;font-size:11px">H</div>
      <div class="bubble-wrap">
        <div class="bubble bubble-green">${nl2br(branch.msg2.body)}<div class="bubble-meta">12:06 PM ✓✓</div></div>
        <div class="btns-wrap" id="btns2-${catKey}">${b2Html}</div>
      </div>`;
    chatEl.appendChild(msg2Div);
    chatEl.scrollTop = chatEl.scrollHeight;

  } else if(msgType===2){ // MSG2 clicked
    document.querySelectorAll(`#btns2-${catKey} .flow-btn`).forEach(b=>{b.classList.add('disabled');b.classList.remove('selected')});
    el.classList.remove('disabled'); el.classList.add('selected');
    const bIdx = flowState[catKey]?.branch ?? 0;
    const branch = cat.branches[bIdx];

    ['msg3-'+catKey,'step3-'+catKey].forEach(id=>{const e=document.getElementById(id);if(e)e.remove()});

    const stepDiv = document.createElement('div');
    stepDiv.id = 'step3-'+catKey; stepDiv.className='step-label';
    stepDiv.textContent = `Sub-selection: "${branch.msg2.btns[btnIdx]}" → recommendation engine fires`;
    chatEl.appendChild(stepDiv);

    const msg3Div = document.createElement('div');
    msg3Div.id = 'msg3-'+catKey; msg3Div.className='msg-row';
    const b3Html = branch.msg3.btns.map(b=>`<button class="flow-btn cta">${escHtml(b)}</button>`).join('');
    const productCard = `<div class="product-card">
      <div class="pname">{{product_name}}</div>
      <div class="pdesc">Best for: {{goal_copy}}</div>
      <div class="prow"><span class="pprice">₹{{price}}</span><span class="prating">⭐ {{rating}} · {{reviews}} reviews</span></div>
    </div>`;
    const bodyPreview = branch.msg3.body.split('\n').slice(0,3).join('\n');
    msg3Div.innerHTML = `<div class="sim-avatar" style="width:28px;height:28px;font-size:11px">H</div>
      <div class="bubble-wrap">
        <div class="bubble bubble-green">${nl2br(bodyPreview)}<br>${productCard}<div class="bubble-meta">12:07 PM ✓✓</div></div>
        <div class="btns-wrap">${b3Html}</div>
      </div>`;
    chatEl.appendChild(msg3Div);
    chatEl.scrollTop = chatEl.scrollHeight;
  }
}

function resetFlow(catKey){
  const cat = CATS.find(c=>c.key===catKey);
  const chatEl = document.getElementById('chat-'+catKey);
  ['msg2-'+catKey,'msg3-'+catKey,'step2-'+catKey,'step3-'+catKey].forEach(id=>{const e=document.getElementById(id);if(e)e.remove()});
  document.querySelectorAll(`#btns1-${catKey} .flow-btn`).forEach(b=>{b.classList.remove('disabled','selected')});
  delete flowState[catKey];
  chatEl.scrollTop=0;
}

// ─────────────────────────────────────────────
// TABS + INIT
// ─────────────────────────────────────────────
function init(){
  const tabsWrap = document.getElementById('tabsWrap');
  const panelsWrap = document.getElementById('panelsWrap');

  CATS.forEach((cat,i)=>{
    const btn = document.createElement('button');
    btn.className = 'tab-btn' + (i===0?' active':'');
    btn.textContent = cat.emoji+' '+cat.name;
    btn.style.setProperty('--cat-color', cat.color);
    if(i===0) btn.style.color = cat.color;
    btn.onclick = ()=>{
      document.querySelectorAll('.tab-btn').forEach(b=>{b.classList.remove('active');b.style.color='';});
      document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
      btn.classList.add('active');
      btn.style.color = cat.color;
      document.getElementById('panel-'+cat.key).classList.add('active');
    };
    tabsWrap.appendChild(btn);
    panelsWrap.innerHTML += buildPanel(cat);
  });

  document.getElementById('panel-'+CATS[0].key).classList.add('active');
}

init();
</script>
</body>
</html>
